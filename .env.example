# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/learnxchange
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/learnxchange
MONGO_URI=mongodb://127.0.0.1:27017/learnxchange

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── Cloudinary ───────────────────────────────────────────
# Get these from https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
